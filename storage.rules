rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isGoogleUser() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'google.com';
    }

    function isTrialExercise(exerciseId) {
      return firebase.database().child('config/trialExerciseId').val() == exerciseId;
    }

    match /audio-exercises/{exerciseId}/{allPaths=**} {
      allow read: if isTrialExercise(exerciseId) || isGoogleUser();
      allow write: if false;
    }
  }
}
